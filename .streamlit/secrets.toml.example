# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is gitignored and must NEVER be committed.
#
# On Streamlit Cloud, add these same key-value pairs via:
#   App Settings → Secrets

[mongo]
uri     = "mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"
db_name = "implicit_bias_study"
